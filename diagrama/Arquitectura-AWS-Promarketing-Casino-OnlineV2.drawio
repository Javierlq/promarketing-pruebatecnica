        <mxCell id="sglegend" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDECEA;strokeColor=#DD344C;dashed=1;dashPattern=8 4;fontColor=#7A1F2B;fontSize=11;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;" value="&lt;b&gt;SECURITY GROUP FLOW&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;sg-alb&lt;/b&gt; (ALB)&lt;br&gt;• in 0.0.0.0/0 :443 (HTTPS)&lt;br&gt;• in 0.0.0.0/0 :80 (HTTP→301)&lt;br&gt;• out 10.0.0.0/16 :80-8082 (EC2)&lt;br&gt;&lt;br&gt;&lt;b&gt;sg-ec2&lt;/b&gt; (EC2 apps)&lt;br&gt;• in desde sg-alb :80/:8080/:8081/:8082&lt;br&gt;• out 0.0.0.0/0 :443 (NAT + endpoint)&lt;br&gt;• out 10.0.0.0/16 :5432 (RDS)&lt;br&gt;• out 10.0.0.0/16 :6379 (Redis)&lt;br&gt;• out 10.1.0.0/16 :5439 (Redshift)&lt;br&gt;&lt;br&gt;&lt;b&gt;sg-rds&lt;/b&gt; (PostgreSQL)&lt;br&gt;• in desde sg-ec2 :5432&lt;br&gt;• sin egress explícito (stateful)&lt;br&gt;&lt;br&gt;&lt;b&gt;sg-redis&lt;/b&gt; (ElastiCache)&lt;br&gt;• in desde sg-ec2 :6379&lt;br&gt;• sin egress explícito (stateful)&lt;br&gt;&lt;br&gt;&lt;b&gt;sg-redshift&lt;/b&gt; (Redshift)&lt;br&gt;• in 10.0.0.0/16 :5439 (peering)&lt;br&gt;• sin egress explícito (stateful)&lt;br&gt;&lt;br&gt;&lt;b&gt;sg-vpce&lt;/b&gt; (Endpoints)&lt;br&gt;• in subredes priv. :443&lt;br&gt;&lt;br&gt;&lt;b&gt;NACLs&lt;/b&gt;&lt;br&gt;• púb: 80/443 + 1024-65535&lt;br&gt;• priv: 80/8080/8081/8082&lt;br&gt;  (10.0.0.0/16) + efímeros&lt;br&gt;• datos: 5439 + efímeros" vertex="1">
          <mxGeometry height="1060" width="315" x="40" y="300" as="geometry" />
        </mxCell>
